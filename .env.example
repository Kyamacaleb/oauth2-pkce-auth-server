
# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/oauth2_pkce_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# --- App ---
# Local dev: http://localhost:8080
# Production: https://auth.yourdomain.com
APP_BASE_URL=http://localhost:8080

# --- RSA Keys (JWT signing) ---
# Leave blank here. Generate with: bash scripts/generate-keys.sh --write-env
# If blank, app uses an ephemeral key (tokens lost on restart - fine for dev)
RSA_PRIVATE_KEY=
RSA_PUBLIC_KEY=

# --- Session ---
# false for local, true for production (needs HTTPS)
SESSION_SECURE=false

# --- Default user (dev only) ---
# Set true to auto-create a user on startup
SEED_DEFAULT_USER=false
DEFAULT_USER_EMAIL=user@example.com
DEFAULT_USER_PASSWORD=